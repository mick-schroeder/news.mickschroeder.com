    "format:check": "prettier --check .",
    "check-updates": "npm-check-updates",
    "check-updates-minor": "npm-check-updates --target minor",
    "upgrade": "npm-check-updates -u && npm install",
    "upgrade-minor": "npm-check-updates --target minor -u && npm install"
  },
